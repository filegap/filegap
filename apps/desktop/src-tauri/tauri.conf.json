{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Filegap Desktop",
  "version": "0.1.0",
  "identifier": "it.drw.filegap.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Filegap Desktop",
        "width": 1200,
        "height": 820,
        "minWidth": 980,
        "minHeight": 700
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": false
  }
}
